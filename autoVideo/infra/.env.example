# ============================================================
# autoVideo 生产环境变量模板
# 使用方式：cp infra/.env.example infra/.env
#           然后填入真实值
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=替换为强密码
POSTGRES_DB=postgres

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=替换为Redis密码

# ── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=替换为MinIO密码

# ── JWT（所有服务必须一致）────────────────────────────────────
# 生成命令：openssl rand -hex 32
JWT_ACCESS_SECRET=替换为32字节随机hex
JWT_REFRESH_SECRET=替换为32字节随机hex

# ── BYOK 加密密钥（auth-service）────────────────────────────
# 生成命令：openssl rand -hex 16
ENCRYPTION_KEY=替换为16字节随机hex

# ── 内部服务调用 Token（pipeline-service）───────────────────
# 生成命令：openssl rand -hex 24
INTERNAL_TOKEN=替换为内部鉴权token

# ── LLM API Keys（script-service）───────────────────────────
LLM_PROVIDER=openai                          # openai / claude / qwen
OPENAI_API_KEY=sk-替换为OpenAI密钥
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Claude（可选，当 LLM_PROVIDER=claude 时使用）
CLAUDE_API_KEY=sk-ant-替换为Claude密钥
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-3-haiku-20240307

# ── 图像生成 API Keys（image-service）───────────────────────
REPLICATE_API_KEY=r8_替换为Replicate密钥       # Flux 图像生成
DALLE_API_KEY=sk-替换为OpenAI密钥              # DALL-E 3（可复用 OPENAI_API_KEY）
TONGYI_API_KEY=sk-替换为阿里云DashScope密钥     # 通义万象
COMFYUI_URL=http://comfyui:8188               # ComfyUI 本地部署地址（SDXL）

# ── 视频生成 API Keys（video-service）───────────────────────
KLING_API_KEY=替换为快手可灵密钥
KLING_BASE_URL=https://api.klingai.com
WAN_API_KEY=替换为火山引擎密钥
WAN_BASE_URL=https://visual.volcengineapi.com

# ── CDN / 存储（storage-service）────────────────────────────
CDN_BASE_URL=http://替换为你的域名:9000        # 本地 MinIO 或真实 CDN 地址
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# ── 前端 ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/
NEXT_PUBLIC_WS_URL=
API_PROXY_TARGET=http://gateway:8000

# ── 监控 ─────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=替换为Grafana密码
